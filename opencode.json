{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "instructions": ["CLAUDE.md"],
  "mcp": {
    "shard": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "docker run --rm -i --init -p 7777:8080 -v \"$PWD/.temp:/data\" -v \"$PWD/app/dist:/srv:ro\" -e HOME=/root -e SHARD_KEY=\"000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f\" -e SHARD_DATA=/data shard-int"
      ],
      "enabled": true,
      "environment": {
        "MSYS_NO_PATHCONV": "1"
      }
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    },
    "context-mode": {
      "type": "local",
      "command": ["npx", "-y", "context-mode@latest"],
      "enabled": true
    }
  }
}
