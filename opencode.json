{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md",
    "SHARDS.md",
    "docs/VISION.md",
    "docs/roadmap.md",
    "docs/CONCEPT.txt"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**"
    ]
  },
  "plugin": [
    "context-mode",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "shard": {
      "type": "local",
      "command": [
        "./mcp.sh"
      ],
      "enabled": true,
      "timeout": 60000
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "context-mode": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "context-mode@1.0.52"
      ],
      "enabled": true
    }
  }
}
