{
  "mcpServers": {
    "shard": {
      "command": "bash",
      "args": ["./mcp.sh"],
      "timeout": 60
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "context-mode": {
      "command": "npx",
      "args": ["-y", "context-mode@1.0.52"]
    }
  }
}
